#!/usr/bin/env bash
#MISE description="Lint Lua with luacheck"
set -euo pipefail

echo "=== Linting Lua (luacheck) ==="
LUACHECK_BIN="$(mise where lua@5.5)/luarocks/bin/luacheck"
if [ -x "$LUACHECK_BIN" ]; then
  "$LUACHECK_BIN" --config nvim/.config/nvim/.luacheckrc nvim/.config/nvim/lua/ 2>/dev/null || true
else
  echo "WARNING: luacheck not found at $LUACHECK_BIN — skipping Lua lint"
fi
