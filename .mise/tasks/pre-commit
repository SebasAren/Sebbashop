#!/usr/bin/env bash
#MISE description="Format, lint, typecheck, and test"
set -euo pipefail

failed=()

capture_dir="$(mktemp -d)"
trap 'rm -rf "$capture_dir"' EXIT

run() {
    local task="$1"
    local out_file="$capture_dir/$task.out"
    if mise run "$task" > "$out_file" 2>&1; then
        echo "✓ $task"
    else
        echo "✗ $task"
        failed+=("$task")
        echo "--- $task output ---"
        cat "$out_file"
        echo "--- end $task ---"
    fi
}

run lint-changed
run typecheck
run test

if [ ${#failed[@]} -gt 0 ]; then
    echo ""
    echo "Failed tasks: ${failed[*]}"
    echo "Run individually for details: mise run <task>"
    exit 1
fi
